# !KKyt-dlp_Windows.spec

# Binaries & Large Files
bin/
*.app
*.dmg
*.exe
*.zip
*.tar.gz

# OS Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project Specific
cookies.txt
*.log
